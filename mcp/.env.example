TID_CLIENT_ID=
TID_REDIRECT_URI=http://localhost:8765/callback
TID_SCOPE="openid processing.read"
TID_REQUIRED_SCOPES=processing.read
TID_ALLOW_AMBIENT_TOKEN=true
TID_AMBIENT_TOKEN_HEADER=authorization
TID_TOKEN_SOURCE_ORDER=ambient,cached,pkce
TID_ALLOWED_AUDIENCES=
