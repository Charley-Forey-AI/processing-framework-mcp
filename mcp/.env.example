MCP_HOST=127.0.0.1
MCP_PORT=3000
MCP_PATH=/mcp
MCP_CORS_ORIGINS=*
MCP_API_KEY=
MCP_SESSION_TTL_MS=1800000

PF_TIMEOUT_MS=20000
PF_RETRY_COUNT=2
PF_READ_ONLY_MODE=false
PF_REQUIRE_MUTATION_CONFIRMATION=false
