{
  "name": "pf-processing-mcp",
  "version": "1.0.0",
  "description": "Streamable HTTP MCP server for Trimble Processing Framework",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/server.ts",
    "start:stdio": "tsx src/stdio.ts",
    "auth:validate": "tsx scripts/local-auth-validate.ts",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "trimble",
    "processing-framework"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
